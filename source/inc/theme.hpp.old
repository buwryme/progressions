#pragma once
#include <string>

namespace Progressions::Theme {

inline constexpr const char* CSS = R"css(

/* ── Root ─────────────────────────────────────────────────────────────────── */
window, .background {
    background-color: #F2F2F7;
    color: #1C1C1E;
}

window.dialog {
    background-color: #F2F2F7;
}

/* ── Typography ─────────────────────────────────────────────────────────────── */
.title-1 {
    font-size: 28px;
    font-weight: 700;
    color: #1C1C1E;
    letter-spacing: -0.5px;
}
.title-2 {
    font-size: 20px;
    font-weight: 600;
    color: #1C1C1E;
}
.title-3 {
    font-size: 16px;
    font-weight: 600;
    color: #1C1C1E;
}
.body {
    font-size: 14px;
    color: #3A3A3C;
}
.caption {
    font-size: 12px;
    color: #8E8E93;
}
.caption-mono {
    font-size: 11px;
    font-family: monospace;
    color: #8E8E93;
}

/* ── Cards ──────────────────────────────────────────────────────────────────── */
.card {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.06);
    padding: 16px;
}
.card:hover {
    background-color: #FAFAFA;
}
.card-tight {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.06);
    padding: 12px 16px;
}

/* ── Buttons ────────────────────────────────────────────────────────────────── */
button.primary {
    background: #007AFF;
    color: #FFFFFF;
    border-radius: 10px;
    border: none;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 1px 3px rgba(0,122,255,0.3);
    transition: background 150ms ease;
}
button.primary:hover {
    background: #0066D6;
}
button.primary:active {
    background: #0055B3;
}
button.primary:disabled {
    background: #C7C7CC;
    box-shadow: none;
}

button.destructive-action {
    background: #FF3B30;
    color: #FFFFFF;
    border-radius: 10px;
    border: none;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
}
button.destructive-action:hover {
    background: #D70015;
}

button.secondary {
    background: rgba(0,0,0,0.05);
    color: #007AFF;
    border-radius: 10px;
    border: none;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    transition: background 150ms ease;
}
button.secondary:hover {
    background: rgba(0,122,255,0.1);
}

button.flat-icon {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 6px;
    color: #007AFF;
}
button.flat-icon:hover {
    background: rgba(0,122,255,0.1);
}

/* ── Separators ─────────────────────────────────────────────────────────────── */
separator {
    background-color: rgba(0,0,0,0.08);
    min-height: 1px;
}

/* ── Progress Bars ──────────────────────────────────────────────────────────── */
progressbar {
    border-radius: 999px;
}
progressbar trough {
    background-color: rgba(0,122,255,0.15);
    border-radius: 999px;
    min-height: 8px;
}
progressbar progress {
    background-color: #007AFF;
    border-radius: 999px;
    min-height: 8px;
    transition: all 200ms ease;
}
progressbar.thin trough { min-height: 4px; }
progressbar.thin progress { min-height: 4px; }
progressbar.success trough { background-color: rgba(52,199,89,0.2); }
progressbar.success progress { background-color: #34C759; }
progressbar.warning trough { background-color: rgba(255,159,10,0.2); }
progressbar.warning progress { background-color: #FF9F0A; }
progressbar.error trough { background-color: rgba(255,59,48,0.2); }
progressbar.error progress { background-color: #FF3B30; }

/* ── Terminal / Output ──────────────────────────────────────────────────────── */
.terminal-view {
    background-color: #1C1C1E;
    border-radius: 10px;
    padding: 12px;
    color: #F2F2F7;
    font-family: monospace;
    font-size: 12px;
}
.terminal-view text {
    background-color: #1C1C1E;
    color: #F2F2F7;
    font-family: "Cascadia Code", "JetBrains Mono", "Fira Code", monospace;
    font-size: 12px;
}

/* ── Speed/Stats badge ──────────────────────────────────────────────────────── */
.speed-badge {
    background: rgba(0,122,255,0.1);
    color: #007AFF;
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 12px;
    font-weight: 600;
    font-family: monospace;
}
.stat-badge {
    background: rgba(0,0,0,0.05);
    color: #636366;
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 12px;
    font-weight: 500;
}

/* ── Command rows ───────────────────────────────────────────────────────────── */
.command-row {
    background-color: #FFFFFF;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.06);
    padding: 12px 16px;
    margin: 4px 0;
    transition: background 120ms ease;
}
.command-row:hover {
    background-color: #F8F8FC;
}
.command-row.running {
    border-color: rgba(0,122,255,0.3);
    background: rgba(0,122,255,0.04);
}
.command-row.done {
    border-color: rgba(52,199,89,0.3);
    background: rgba(52,199,89,0.04);
}
.command-row.failed {
    border-color: rgba(255,59,48,0.3);
    background: rgba(255,59,48,0.04);
}
.command-row.skipped {
    opacity: 0.5;
}

/* ── Status pill ─────────────────────────────────────────────────────────────── */
.status-pill {
    border-radius: 999px;
    padding: 2px 10px;
    font-size: 11px;
    font-weight: 600;
}
.status-pill.pending  { background: rgba(142,142,147,0.15); color: #636366; }
.status-pill.running  { background: rgba(0,122,255,0.15);   color: #007AFF; }
.status-pill.done     { background: rgba(52,199,89,0.15);   color: #34C759; }
.status-pill.failed   { background: rgba(255,59,48,0.15);   color: #FF3B30; }
.status-pill.skipped  { background: rgba(142,142,147,0.1);  color: #8E8E93; }

/* ── Countdown ring / reboot ─────────────────────────────────────────────────── */
.countdown-label {
    font-size: 56px;
    font-weight: 700;
    color: #FF3B30;
    font-variant-numeric: tabular-nums;
}

/* ── Switch ──────────────────────────────────────────────────────────────────── */
switch {
    border-radius: 999px;
}
switch:checked {
    background-color: #34C759;
}

/* ── Entry ──────────────────────────────────────────────────────────────────── */
entry {
    background-color: #FFFFFF;
    border-radius: 8px;
    border: 1px solid rgba(0,0,0,0.1);
    padding: 8px 12px;
    font-size: 14px;
}
entry:focus {
    border-color: #007AFF;
    box-shadow: 0 0 0 3px rgba(0,122,255,0.2);
}

/* ── Header bar ─────────────────────────────────────────────────────────────── */
headerbar {
    background-color: rgba(242,242,247,0.85);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    min-height: 48px;
}
headerbar .title { font-weight: 600; }

/* ── List box ────────────────────────────────────────────────────────────────── */
listbox {
    background: transparent;
}
listbox row {
    background: transparent;
    border-radius: 10px;
    padding: 4px;
}
listbox row:hover {
    background: rgba(0,0,0,0.04);
}
listbox row:selected {
    background: rgba(0,122,255,0.1);
    color: #007AFF;
}

/* ── Scrollbar ───────────────────────────────────────────────────────────────── */
scrollbar {
    background: transparent;
}
scrollbar slider {
    background: rgba(0,0,0,0.15);
    border-radius: 999px;
    min-width: 6px;
    min-height: 6px;
}
scrollbar slider:hover {
    background: rgba(0,0,0,0.25);
}

/* ── Divider line ────────────────────────────────────────────────────────────── */
.divider {
    background-color: rgba(0,0,0,0.07);
}

)css";

} // namespace Progressions::Theme
